# ══════════════════════════════════════════════════════════════════════════════
# pi-monitor — environment configuration
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# BOT_TOKEN, ALLOWED_USER_IDS, and DESKTOP_PATH are required.
# ══════════════════════════════════════════════════════════════════════════════


# ── Timezone ──────────────────────────────────────────────────────────────────

# IANA timezone name for all display timestamps and scheduler (default: UTC).
# Cron expressions and daily times in plugins.yml are interpreted in this tz.
# Examples: UTC  Europe/Berlin  America/New_York  Asia/Tokyo
TZ=Europe/Chisinau


# ── Required ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram user ID(s) — comma-separated. The bot ignores all other users.
# Find your ID by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=


# ── Paths ─────────────────────────────────────────────────────────────────────

# Absolute path to the user's Desktop on the *host* (not inside the container).
# Must match the host bind-mount path exactly so that `docker compose` calls
# inside the bot container resolve volume paths the daemon can understand.
# Set this to your actual Desktop path:
#   Raspberry Pi:  DESKTOP_PATH=/home/pi/Desktop
#   Debian host:   DESKTOP_PATH=/home/yourname/Desktop
#   macOS host:    DESKTOP_PATH=/Users/yourname/Desktop
#   Custom user:   DESKTOP_PATH=/home/yourname/Desktop
DESKTOP_PATH=

# Where the bot stores its persistent container registry.
# Defaults to /data/registry.json (inside the container, mapped to ./bot-data/).
# REGISTRY_PATH=/data/registry.json

# Where the bot stores active mutes (container/family/all scopes).
# Defaults to /data/mutes.json (inside the container, mapped to ./bot-data/).
# MUTE_STORE_PATH=/data/mutes.json

# Path to the plugins configuration file (inside the container).
# Defaults to /app/config/plugins.yml (baked into the image at build time).
# Override to use a file from the bot-data volume instead:
#   PLUGINS_YML_PATH=/data/plugins.yml
# PLUGINS_YML_PATH=/app/config/plugins.yml


# ── Telegram API ──────────────────────────────────────────────────────────────

# By default the bot connects directly to Telegram's cloud servers.
# If you run a local Bot API server (for higher rate limits / large files),
# set this to your local server address, e.g.:
#   TELEGRAM_API_BASE_URL=http://telegram-bot-api:8081/bot
# TELEGRAM_API_BASE_URL=https://api.telegram.org/bot


# ── Alert thresholds ──────────────────────────────────────────────────────────

# Alert fires when usage crosses this percentage.
DISK_THRESHOLD_PCT=90
RAM_THRESHOLD_PCT=90
SWAP_THRESHOLD_PCT=80

# Alert fires when 1-minute load average per core exceeds this value.
CPU_LOAD_THRESHOLD=3.0

# Alert fires when SoC/CPU temperature exceeds this (Celsius).
TEMP_THRESHOLD_C=75

# Minimum minutes between repeated alerts for the same issue.
ALERT_COOLDOWN_MINUTES=10


# ── Optional: Beszel monitoring ───────────────────────────────────────────────
# Only needed if you start the monitoring profile:
#   docker compose --profile monitoring up -d
#
# Generate the key from the Beszel web UI after first login:
#   Systems → Add system → copy the public KEY field.
# Leave empty on first deploy; add after Beszel hub is running.
BESZEL_KEY=
